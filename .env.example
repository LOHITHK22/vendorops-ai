# Application
APP_NAME="VendorOps AI"
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/v1

# Database
# Local development defaults to SQLite. Docker/production should use PostgreSQL.
DATABASE_URL=sqlite+aiosqlite:///./vendorops.db
# DATABASE_URL=postgresql+asyncpg://vendorops:vendorops@localhost:5432/vendorops

# File storage
LOCAL_STORAGE_DIR=./storage
REPORTS_DIR=./reports_out

# LLM provider
# Leave empty to use the mock extractor in Phase 4.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
EXTRACTION_MAX_ATTEMPTS=3
EXTRACTION_RETRY_BASE_SECONDS=0.4
LLM_INPUT_COST_PER_1K_TOKENS=0.0004
LLM_OUTPUT_COST_PER_1K_TOKENS=0.0016

# Demo SaaS identity seed
AUTH_TOKEN_TTL_HOURS=12
DEMO_ADMIN_EMAIL=admin@vendorops.ai
DEMO_ADMIN_PASSWORD=VendorOpsDemo123!
DEFAULT_ORGANIZATION_NAME="VendorOps Demo Co"
DEFAULT_WORKSPACE_NAME="Finance Operations"
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
