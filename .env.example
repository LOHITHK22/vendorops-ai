# Application
APP_NAME="VendorOps AI"
APP_ENV=local
APP_DEBUG=true
API_PREFIX=/v1

# Database
# SQLite is the Phase 0/early MVP default. Later phases keep the design PostgreSQL-ready.
DATABASE_URL=sqlite+aiosqlite:///./vendorops.db

# File storage
LOCAL_STORAGE_DIR=./storage

# LLM provider
# Leave empty to use the mock extractor in Phase 4.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Logging
LOG_LEVEL=INFO
